{
  "permissions": {
    "allow": [
      "Read(src/**)",
      "Read(public/**)",
      "Read(content/**)",
      "Read(*.config.*)",
      "Read(package.json)",
      "Read(tsconfig.json)",
      "Read(.claude/**)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm format)",
      "Bash(pnpm add *)",
      "Bash(pnpm dlx *)",
      "Bash(git *)"
    ],
    "deny": [
      "Read(.env*)",
      "Bash(rm -rf *)",
      "Bash(pnpm publish)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE\"; case \"$file\" in *.ts|*.tsx) npx tsc --noEmit --pretty 2>&1 | head -20 ;; esac"
          }
        ]
      }
    ]
  }
}